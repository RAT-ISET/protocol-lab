set(CPACK_PACKAGE_NAME ${PROJECT_NAME})
set(CPACK_PACKAGE_VERSION ${PROJECT_FULL_VERSION})
set(CPACK_PACKAGE_VENDOR "ISET")
set(CPACK_PACKAGE_CONTACT "ratiset@outlook.com")
set(CPACK_DEBIAN_PACKAGE_MAINTAINER "Team ISET")
set(CPACK_DEBIAN_PACKAGE_DEPENDS "")
set(CPACK_RPM_PACKAGE_LICENSE "MIT")
set(CPACK_OUTPUT_FILE_PREFIX ${CMAKE_SOURCE_DIR}/out/dist)
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY ${PROJECT_DESCRIPTION})

if (CMAKE_HOST_SYSTEM_NAME MATCHES "Windows")
    set(CPACK_PACKAGE_VERSION ${PROJECT_VERSION})
    set(CPACK_GENERATOR "NSIS;ZIP;WIX")
    set(CPACK_WIX_VERSION 3)
    set(CPACK_WIX_UPGRADE_GUID "" CACHE STRING "WiX Upgrade GUID")
    set(CPACK_NSIS_MODIFY_PATH ON)
    set(CPACK_RESOURCE_FILE_LICENSE "${CMAKE_SOURCE_DIR}/LICENSE.rtf")
elseif (CMAKE_HOST_SYSTEM_NAME MATCHES "Darwin")
    set(CPACK_GENERATOR "DragNDrop;TGZ")
    set(CPACK_RESOURCE_FILE_LICENSE "${CMAKE_SOURCE_DIR}/LICENSE.rtf")
elseif (CMAKE_HOST_SYSTEM_NAME MATCHES "Linux")
    set(CPACK_GENERATOR "TGZ;DEB")
    set(CPACK_RESOURCE_FILE_LICENSE "${CMAKE_SOURCE_DIR}/LICENSE.txt")
endif ()

include(CPack)
